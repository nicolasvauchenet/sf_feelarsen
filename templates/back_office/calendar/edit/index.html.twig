{% extends 'back_office/layout/_index.html.twig' %}

{% block title %}Modifier un Calendrier{% endblock %}

{% block main %}
    <section class="app-section cover" data-navigation-target="section">
        <img src="{{ asset('img/admincover.webp') }}" alt="Administration"/>
        <h1>Modifier un Calendrier</h1>
    </section>

    <section class="app-section actions">
        <a href="{{ path('app_back_office_calendar_home') }}">
            {{ ux_icon('fa6-solid:circle-arrow-left', {'class': 'app-icon medium'}) }}
            Les Concerts
        </a>

        <a href="{{ path('app_back_office_calendar_delete', {'id': calendar.id}) }}"
           class="text-danger"
           onclick="return window.confirm('⚠ Attention ⚠\nToutes les dates de ce calendrier seront supprimées !\nÊtes-vous sûr ?')">
            {{ ux_icon('fa6-solid:trash-can', {'class': 'app-icon medium'}) }}
            Supprimer
        </a>
    </section>

    <section class="app-section form">
        {% include 'back_office/calendar/_form.html.twig' with {'button_label': 'Modifier'} %}
    </section>
{% endblock %}
