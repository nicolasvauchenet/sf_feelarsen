{{ form_start(form, {'attr': {'class': 'app-form'}}) }}
<fieldset class="form-fieldset">
    <legend class="form-legend">Informations du Concert</legend>

    <div class="form-group">
        {{ form_label(form.location) }}
        {{ form_widget(form.location) }}
        {{ form_errors(form.location) }}
    </div>

    <div class="form-group">
        {{ form_label(form.city) }}
        {{ form_widget(form.city) }}
        {{ form_errors(form.city) }}
    </div>

    <div class="form-group">
        {{ form_label(form.poster) }}
        {% if date is defined and date.poster %}
            <div class="app-grid third">
                <div class="file">
                    {{ form_widget(form.poster) }}
                    <p>{{ date.poster }}</p>
                    <p>
                        <a href="{{ path('app_back_office_date_poster_delete', {'id': date.id}) }}"
                           class="text-danger"
                           onclick="return window.confirm('Êtes-vous sûr ?')">Supprimer
                        </a>
                    </p>
                </div>
                <div class="preview">
                    <a href="{{ asset('uploads/calendar/' ~ date.calendar.slug ~ '/' ~ date.poster) }}" target="_blank">
                        <img src="{{ asset('uploads/calendar/' ~ date.calendar.slug ~ '/' ~ date.poster) }}"
                             alt="{{ date.location }}"/>
                    </a>
                </div>
            </div>
        {% else %}
            {{ form_widget(form.poster) }}
        {% endif %}
        {{ form_errors(form.poster) }}
    </div>

    <div class="form-group">
        {{ form_label(form.link) }}
        {{ form_widget(form.link) }}
        {{ form_errors(form.link) }}
    </div>
</fieldset>

<fieldset class="form-fieldset">
    <legend class="form-legend">Gestion du Concert</legend>

    <div class="form-group toggle">
        {{ form_label(form.active, null, {'label_attr': {'class': 'toggle-label'}}) }}
        {{ form_widget(form.active) }}
        <div class="toggle-switch"></div>
    </div>

    <div class="form-group">
        {{ form_label(form.calendar) }}
        {{ form_widget(form.calendar) }}
        {{ form_errors(form.calendar) }}
    </div>

    <div class="form-group">
        {{ form_label(form.startAt) }}
        {{ form_widget(form.startAt) }}
        {{ form_errors(form.startAt) }}
    </div>
</fieldset>

<div class="form-group">
    {{ form_widget(form._token) }}

    <button type="submit" class="form-submit">{{ button_label|default('Créer') }}</button>
</div>
{{ form_end(form, {'render_rest': false}) }}
