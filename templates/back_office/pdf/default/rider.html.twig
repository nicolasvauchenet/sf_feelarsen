<html>
    <head>
        <meta charset="UTF-8"/>
        <title>{{ app_settingsService.settings.siteName }} - Rider</title>

        <style>
            {% include 'back_office/pdf/default/styles.css' %}
            @page content-page {
                @bottom-left {
                    content: "{{ app_settingsService.settings.siteName }} - Rider";
                }
            }
        </style>
    </head>
    <body>
        <!-- Couverture -->
        <section class="cover-page home">
            <svg class="cover-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 210 260">
                <defs>
                    <clipPath id="clip-shape">
                        <path d="M 0 0 H 210 V 160 Q 105 260 0 160 Z"/>
                    </clipPath>
                </defs>
                <image href="file:///app/uploads/settings/{{ app_settingsService.settings.siteCover }}"
                       width="210"
                       height="260"
                       clip-path="url(#clip-shape)"
                       preserveAspectRatio="xMidYMid slice"/>
            </svg>

            <div class="filetitle">
                <h1>{{ app_settingsService.settings.siteName }}</h1>
                <h2>Rider</h2>
            </div>

            <div class="grid three">
                <p>&nbsp;</p>

                <div class="grid-item">
                    <h3>Contact Artistique</h3>
                    <p>
                        <strong>Jean-François Capéran</strong>
                        <br/>
                        06.31.24.90.65
                    </p>
                </div>

                <p>&nbsp;</p>
            </div>
        </section>

        {% include 'back_office/pdf/default/rider/_content.html.twig' %}

        <!-- Saut de page -->
        <div class="page-break"></div>

        <!-- Back -->
        {% include 'back_office/pdf/default/_back.html.twig' %}
    </body>
</html>
