                    </p>
                </div>
                <div class="preview">
                    <a href="{{ asset('uploads/settings/' ~ settings.siteCover) }}" target="_blank">
                        <img src="{{ asset('uploads/settings/' ~ settings.siteCover) }}"
                             alt="{{ app_settingsService.settings.siteName }}"/>
                    </a>
                </div>
            </div>
        {% else %}
            {{ form_widget(form.siteCover) }}
        {% endif %}
        {{ form_errors(form.siteCover) }}
    </div>
</fieldset>

