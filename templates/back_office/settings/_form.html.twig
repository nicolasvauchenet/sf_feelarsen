{{ form_start(form, {'attr': {'class': 'app-form'}}) }}
<fieldset class="form-fieldset">
    <legend class="form-legend">Informations du Site</legend>

    <div class="form-group">
        {{ form_label(form.siteName) }}
        {{ form_widget(form.siteName) }}
        {{ form_errors(form.siteName) }}
    </div>

    <div class="form-group">
        {{ form_label(form.sitePunchline) }}
        {{ form_widget(form.sitePunchline) }}
        {{ form_errors(form.sitePunchline) }}
    </div>

    <div class="form-group">
        {{ form_label(form.siteLogo) }}
        {% if settings is defined and settings.siteLogo %}
            <div class="app-grid third">
                <div class="file">
                    {{ form_widget(form.siteLogo) }}
                    <p>{{ settings.siteLogo }}</p>
                    <p>
                        <a href="{{ path('app_back_office_settings_image_delete', {'id': settings.id, 'type': 'sitelogo'}) }}"
                           class="text-danger"
                           onclick="return window.confirm('Êtes-vous sûr ?')">
                            Supprimer
                        </a>
                    </p>
                </div>
                <div class="preview">
                    <a href="{{ asset('uploads/settings/' ~ settings.siteLogo) }}" target="_blank">
                        <img src="{{ asset('uploads/settings/' ~ settings.siteLogo) }}"
                             alt="{{ app_settingsService.settings.siteName }}"/>
                    </a>
                </div>
            </div>
        {% else %}
            {{ form_widget(form.siteLogo) }}
        {% endif %}
        {{ form_errors(form.siteLogo) }}
    </div>

    <div class="form-group">
        {{ form_label(form.siteCover) }}
        {% if settings is defined and settings.siteCover %}
            <div class="app-grid third">
                <div class="file">
                    {{ form_widget(form.siteCover) }}
                    <p>{{ settings.siteCover }}</p>
                    <p>
                        <a href="{{ path('app_back_office_settings_image_delete', {'id': settings.id, 'type': 'sitecover'}) }}"
                           class="text-danger"
                           onclick="return window.confirm('Êtes-vous sûr ?')">
                            Supprimer
