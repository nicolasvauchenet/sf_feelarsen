{% extends 'security/layout/_index.html.twig' %}

{% block title %}Authentification{% endblock %}

{% block main %}
    <section class="app-section cover" data-navigation-target="section">
        <img src="{{ asset('img/sitecover.jpg') }}" alt="{{ app_settingsService.settings.siteName }}"/>
        <h1>Connexion</h1>
    </section>

    <section class="app-section form">
        <form method="post" class="app-form">
            <fieldset class="form-fieldset">
                <legend class="form-legend">Vos identifiants</legend>

                <div class="form-group">
                    <label for="username" class="form-label required">Adresse e-mail</label>
                    <input type="email"
                           value="{{ last_username }}"
                           name="_username"
                           id="username"
                           class="form-control"
                           autocomplete="email"
                           required
                           autofocus/>
                </div>

                <div class="form-group">
                    <label for="password" class="form-label required">Mot de passe</label>
                    <input type="password"
                           name="_password"
                           id="password"
                           class="form-control"
                           autocomplete="current-password"
                           required/>
                </div>
            </fieldset>

            <div class="form-group">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}"/>
                <button class="form-submit" type="submit">Connexion</button>
            </div>
        </form>
    </section>
{% endblock %}
